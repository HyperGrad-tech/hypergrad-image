---
import ToolLayout from '../layouts/ToolLayout.astro';
import Base64Image from '../components/tools/Base64Image.tsx';
---
<ToolLayout slug="base64-image">
  <Base64Image client:load />
  <div slot="seo-content">
    <h2>在线 Base64 与图片互转工具</h2>
    <p>图片转 Base64 Data URL，或 Base64 转回图片，支持拖拽和复制。所有编解码在浏览器本地用 FileReader API 完成，图片和 Base64 字符串都不会上传服务器。</p>
    <h3>Base64 Data URL 的典型用途</h3>
    <ul>
      <li><strong>内联小图标</strong>：把 1KB 以内的小图标转成 Base64 嵌入 HTML/CSS，减少 HTTP 请求。</li>
      <li><strong>邮件内嵌图片</strong>：邮件不支持图片附件的可靠显示，可用 Base64 内联。</li>
      <li><strong>JSON API 传输</strong>：在 JSON 中传输图片数据（如生成的二维码、截图）。</li>
      <li><strong>CSS 渐变占位</strong>：低分辨率占位图 Base64 内联，避免布局抖动。</li>
    </ul>
    <h3>不适合 Base64 的场景</h3>
    <p>大图片不要转 Base64 内联：体积会增大 33%，且无法被浏览器缓存（每次加载 HTML 都要重新下载这段 Base64）。一般 1KB 以内的图片适合内联，超过 4KB 的图片建议作为独立资源加载。</p>
  </div>
</ToolLayout>
