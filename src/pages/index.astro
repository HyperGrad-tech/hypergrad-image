---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { tools, priorityMeta, toolsByPriority, type Priority } from '../data/tools';

const priorityOrder: Priority[] = ['P0', 'P1', 'P2'];
const totalTools = tools.length;
import { getSisterSites } from '../data/sisterSites';
const sisters = getSisterSites('image');

const homeSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": "https://hypergrad.cn/#organization",
      "name": "HyperGrad",
      "url": "https://hypergrad.cn/",
      "description": "HyperGrad 是一系列纯前端在线工具 + 本地加密笔记应用的集合站，专注隐私保护与本地化处理。"
    },
    {
      "@type": "WebSite",
      "@id": "https://image.hypergrad.cn/#website",
      "url": "https://image.hypergrad.cn/",
      "name": "HyperGrad Image — 纯前端图片工具箱 · SVG/WebP/EXIF · 100% 本地处理",
      "description": "12 个细分图片工具：SVG 优化/编辑/转PNG、WebP 转换、EXIF 查看/清理、占位图、Base64 互转、颜色提取、图片拼接、GIF 截帧、格式转换。所有图片处理在浏览器本地完成，不上传服务器。",
      "inLanguage": "zh-CN",
      "publisher": {
        "@id": "https://hypergrad.cn/#organization"
      }
    }
  ]
};

---
<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>HyperGrad Image — 纯前端图片工具箱 · SVG/WebP/EXIF · 100% 本地处理</title>
  <meta name="description" content="12 个细分图片工具：SVG 优化/编辑/转PNG、WebP 转换、EXIF 查看/清理、占位图、Base64 互转、颜色提取、图片拼接、GIF 截帧、格式转换。所有图片处理在浏览器本地完成，不上传服务器。" />
  <meta name="keywords" content="图片工具,svg优化,svg转png,webp转换,exif查看,exif清理,占位图,base64转图片,颜色提取,图片拼接,gif截帧,图片格式转换,avif转换" />
  <link rel="canonical" href="https://image.hypergrad.cn/" />
  <meta property="og:title" content="HyperGrad Image — 纯前端图片工具箱" />
  <meta property="og:description" content="12 个细分图片工具，100% 本地处理，图片不离开浏览器。" />
  <meta property="og:type" content="website" />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <!-- Baidu Tongji（跨子域追踪 hypergrad.cn） -->
  <script is:inline>
var _hmt = _hmt || [];
_hmt.push(['_setCookieDomain', '.hypergrad.cn']);
(function() {
  var hm = document.createElement("script");
  hm.src = "https://hm.baidu.com/hm.js?a778461c432b29b641ee950a9f686a65";
  var s = document.getElementsByTagName("script")[0];
  s.parentNode.insertBefore(hm, s);
})();
  </script>
  <!-- home-schema:start -->
  <script type="application/ld+json" set:html={JSON.stringify(homeSchema)} />
  <!-- home-schema:end -->
</head>
<body>
  <!-- DeepSeal 推广条 -->
  <div class="promo-banner" id="promo-banner">
    <span>
      <strong>DeepSeal</strong> — 本地加密笔记应用，你的隐私只有你说了算。
      <a href="https://hypergrad.cn#pricing" target="_blank" rel="noopener">免费下载 →</a>
    </span>
    <span class="promo-close" onclick="document.getElementById('promo-banner').style.display='none'">×</span>
  </div>

  <Header />

  <main class="main" style="max-width: var(--content-max); margin: 0 auto;">
    <!-- 快速导航工具条（置顶，让用户进站即可点工具） -->
    <section class="quick-nav">
      <div class="quick-nav-title">快速访问 · 全部 {totalTools} 个工具</div>
      <div class="quick-nav-chips">
        {tools.map(t => (
          <a href={`/${t.slug}`} class="quick-chip">
            <span class="quick-chip-icon">{t.icon}</span>
            <span>{t.name}</span>
          </a>
        ))}
      </div>
    </section>


    <!-- 按优先级分区 -->
    {priorityOrder.map(p => {
      const list = toolsByPriority(p);
      const meta = priorityMeta[p];
      return (
        <section class="priority-section">
          <div class="priority-header">
            <h2>{meta.label}</h2>
            <span class="priority-tag" style={`background:${meta.bg};color:${meta.color}`}>{p} · {list.length} 个</span>
            <span class="priority-desc">{meta.desc}</span>
          </div>
          <div class="tool-grid">
            {list.map(t => (
              <a href={`/${t.slug}`} class="tool-card-home">
                <div class="card-icon">{t.icon}</div>
                <h3>{t.name}</h3>
                <p>{t.desc}</p>
                <div class="card-meta">
                  <span>{t.category}</span>
                  <span>日均 {t.volume} 搜索</span>
                </div>
              </a>
            ))}
          </div>
        </section>
      );
    })}

<!-- SISTER-CARDS -->
    <section class="sister-sites-section">
      <h2>还需要别的工具？看看姊妹站</h2>
      <p class="sister-section-desc">HyperGrad 一共 5 个工具站，全部本地处理、互不打扰——挑一个继续探索。</p>
      <div class="sister-cards">
        {sisters.map(s => (
          <a href={s.href} class="sister-card" target="_blank" rel="noopener">
            <div class="sister-card-head">
              <span class="sister-card-icon">{s.icon}</span>
              <div class="sister-card-head-text">
                <strong>{s.shortName}</strong>
                <span class="sister-card-href">{s.href.replace('https://', '')}</span>
              </div>
            </div>
            <p class="sister-card-slogan">{s.slogan}</p>
            <ul class="sister-card-tools">
              {s.hot.slice(0, 5).map(h => (
                <li>{h.name}</li>
              ))}
            </ul>
            <span class="sister-card-cta">访问 {s.shortName} →</span>
          </a>
        ))}
      </div>
    </section>

    <!-- 关于 -->
    <section class="seo-content">
      <h2>关于 HyperGrad Image</h2>
      <p>
        HyperGrad Image 是一个纯前端的图片工具集合，收录了 <strong>{totalTools} 个</strong>日常开发与设计中高频使用的细分图片工具。
        与其他图片工具站不同，本站所有图片处理都在<strong>浏览器本地</strong>完成——你上传的 SVG、照片、GIF，
        永远不会通过网络发送到任何服务器。这意味着：
      </p>
      <ul>
        <li><strong>隐私安全</strong>：处理含 EXIF 的私人照片、商业设计稿，无需担心泄露。</li>
        <li><strong>离线可用</strong>：页面加载完成后，断网也能继续使用。</li>
        <li><strong>速度快</strong>：无网络往返，所有操作即时响应。</li>
        <li><strong>无广告</strong>：首年完全无广告，专注于体验。</li>
      </ul>
      <h3>差异化定位：避开 TinyPNG 主战场</h3>
      <p>
        本站刻意避开 PNG/JPG 压缩这个红海（TinyPNG、智图已是霸主），聚焦三个有差异化壁垒的品类：
        <strong>SVG 工具</strong>（优化、编辑、转 PNG）、<strong>现代格式转换</strong>（WebP/AVIF 双向互转）、
        <strong>EXIF 隐私</strong>（查看与清理）。这三个品类与 <a href="https://hypergrad.cn" target="_blank" rel="noopener">DeepSeal 加密笔记应用</a>
        的隐私心智天然契合——<strong>你的数据只有你说了算</strong>。
      </p>
      <h3>与 HyperGrad 生态的关系</h3>
      <p>
        HyperGrad Image 与 <a href="https://devtools.hypergrad.cn" target="_blank" rel="noopener">HyperGrad DevTools 开发者工具站</a>、
        <a href="https://hypergrad.cn" target="_blank" rel="noopener">DeepSeal 加密笔记应用</a> 同属 HyperGrad 生态。
        三款产品共享同一个核心理念：<strong>本地处理、隐私优先、数据不离开设备</strong>。
      </p>
    </section>
    <!-- Hero（精简为一行醒目标语） -->
    <section class="home-hero home-hero-compact home-hero-compact--bottom">
      <h1>纯前端图片工具箱 · <span class="hero-accent">SVG / WebP / EXIF 原图不外传</span></h1>
      <div class="privacy-badge">{totalTools} 个工具 · 100% 本地处理 · 不上传 · 不存储</div>
    </section>

  </main>

  <Footer />

  <style is:global>
    .quick-nav {
      margin: 28px 0 8px;
      padding: 16px 20px;
      background: var(--bg-soft);
      border: 1px solid var(--border);
      border-radius: 12px;
    }
    .quick-nav-title {
      font-size: 12px;
      color: var(--text-muted);
      margin-bottom: 10px;
      font-weight: 600;
      letter-spacing: 0.5px;
    }
    .quick-nav-chips {
      display: flex;
      gap: 8px;
      overflow-x: auto;
      padding-bottom: 4px;
      scrollbar-width: thin;
    }
    .quick-nav-chips::-webkit-scrollbar { height: 6px; }
    .quick-nav-chips::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }
    .quick-chip {
      flex-shrink: 0;
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 6px 14px;
      background: #fff;
      border: 1px solid var(--border);
      border-radius: 20px;
      font-size: 13px;
      color: var(--text);
      text-decoration: none;
      white-space: nowrap;
      transition: all 0.15s ease;
    }
    .quick-chip:hover {
      background: var(--blue);
      color: #fff;
      border-color: var(--blue);
    }
    .quick-chip-icon { font-size: 14px; }

    /* 精简版 hero：单行醒目标语 */
    .home-hero-compact {
      text-align: center;
      padding: var(--space-xl) var(--space-lg) var(--space-lg);
      margin-bottom: var(--space-xl);
    }
    .home-hero-compact h1 {
      font-family: var(--font-sans);
      font-size: 30px;
      font-weight: 800;
      color: var(--text);
      line-height: 1.3;
      margin: 0 0 var(--space-sm);
      letter-spacing: -0.02em;
    }
    .home-hero-compact .hero-accent {
      color: var(--blue);
    }
    .home-hero-compact .privacy-badge {
      font-size: 13px;
      padding: 6px 16px;
    }
  
    /* SISTER-CARDS — 首页姊妹站大卡片 */
    .sister-sites-section {
      margin: var(--space-xl) 0 var(--space-lg);
      padding-top: var(--space-lg);
      border-top: 1px solid var(--border);
    }
    .sister-sites-section h2 {
      font-size: 22px; font-weight: 700;
      color: var(--text);
      margin: 0 0 6px;
      letter-spacing: -0.01em;
    }
    .sister-section-desc {
      font-size: 14px; color: var(--text-muted);
      margin: 0 0 20px;
    }
    .sister-cards {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: 16px;
    }
    .sister-card {
      display: flex; flex-direction: column; gap: 10px;
      padding: 18px;
      background: #fff;
      border: 1px solid var(--border);
      border-radius: 14px;
      text-decoration: none;
      color: var(--text);
      transition: border-color 0.18s ease, box-shadow 0.18s ease, transform 0.18s ease;
    }
    .sister-card:hover {
      border-color: var(--blue);
      box-shadow: 0 8px 24px rgba(99, 102, 241, 0.15);
      transform: translateY(-2px);
    }
    .sister-card-head {
      display: flex; align-items: center; gap: 12px;
    }
    .sister-card-icon {
      font-size: 22px; line-height: 1;
      width: 44px; height: 44px;
      display: flex; align-items: center; justify-content: center;
      background: var(--blue-bg);
      border-radius: 12px;
      flex-shrink: 0;
    }
    .sister-card-head-text {
      display: flex; flex-direction: column; gap: 2px;
      min-width: 0;
    }
    .sister-card-head-text strong {
      font-size: 16px; font-weight: 700; color: var(--text);
    }
    .sister-card-href {
      font-size: 11px; color: var(--text-muted);
    }
    .sister-card-slogan {
      font-size: 13px; color: var(--text-muted);
      line-height: 1.5; margin: 0;
    }
    .sister-card-tools {
      list-style: none; padding: 0; margin: 4px 0 0;
      display: flex; flex-wrap: wrap; gap: 6px 8px;
    }
    .sister-card-tools li {
      font-size: 12px; color: var(--text);
      background: var(--bg-soft);
      padding: 3px 9px;
      border-radius: 12px;
      white-space: nowrap;
    }
    .sister-card-cta {
      margin-top: auto;
      font-size: 13px; font-weight: 600;
      color: var(--blue);
    }

  </style>
</body>
</html>
