---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { tools, priorityMeta, toolsByPriority, type Priority } from '../data/tools';

const priorityOrder: Priority[] = ['P0', 'P1', 'P2'];
const totalTools = tools.length;
---
<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>HyperGrad Image — 纯前端图片工具箱 · SVG/WebP/EXIF · 100% 本地处理</title>
  <meta name="description" content="12 个细分图片工具：SVG 优化/编辑/转PNG、WebP 转换、EXIF 查看/清理、占位图、Base64 互转、颜色提取、图片拼接、GIF 截帧、格式转换。所有图片处理在浏览器本地完成，不上传服务器。" />
  <meta name="keywords" content="图片工具,svg优化,svg转png,webp转换,exif查看,exif清理,占位图,base64转图片,颜色提取,图片拼接,gif截帧,图片格式转换,avif转换" />
  <link rel="canonical" href="https://image.hypergrad.cn/" />
  <meta property="og:title" content="HyperGrad Image — 纯前端图片工具箱" />
  <meta property="og:description" content="12 个细分图片工具，100% 本地处理，图片不离开浏览器。" />
  <meta property="og:type" content="website" />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <!-- Baidu Tongji（跨子域追踪 hypergrad.cn） -->
  <script is:inline>
var _hmt = _hmt || [];
_hmt.push(['_setCookieDomain', '.hypergrad.cn']);
(function() {
  var hm = document.createElement("script");
  hm.src = "https://hm.baidu.com/hm.js?a778461c432b29b641ee950a9f686a65";
  var s = document.getElementsByTagName("script")[0];
  s.parentNode.insertBefore(hm, s);
})();
  </script>
</head>
<body>
  <!-- DeepSeal 推广条 -->
  <div class="promo-banner" id="promo-banner">
    <span>
      <strong>DeepSeal</strong> — 本地加密笔记应用，你的隐私只有你说了算。
      <a href="https://hypergrad.cn#pricing" target="_blank" rel="noopener">免费下载 →</a>
    </span>
    <span class="promo-close" onclick="document.getElementById('promo-banner').style.display='none'">×</span>
  </div>

  <Header />

  <main class="main" style="max-width: var(--content-max); margin: 0 auto;">
    <!-- Hero -->
    <section class="home-hero">
      <div class="privacy-badge">{totalTools} 个工具 · 100% 本地处理 · 图片不离开浏览器</div>
      <h1>纯前端图片工具箱<br>避开压缩红海 聚焦 SVG / WebP / EXIF</h1>
      <p>
        SVG 优化与转换、WebP/AVIF 格式互转、EXIF 查看与清理、占位图生成、颜色提取、GIF 截帧——{totalTools} 个细分图片工具。
        所有处理在浏览器本地完成，原图和新图都不会上传服务器。与 DeepSeal 加密笔记应用同属 HyperGrad 生态。
      </p>
    </section>

    <!-- 快速导航工具条 -->
    <section class="quick-nav">
      <div class="quick-nav-title">快速访问</div>
      <div class="quick-nav-chips">
        {tools.map(t => (
          <a href={`/${t.slug}`} class="quick-chip">
            <span class="quick-chip-icon">{t.icon}</span>
            <span>{t.name}</span>
          </a>
        ))}
      </div>
    </section>

    <!-- 按优先级分区 -->
    {priorityOrder.map(p => {
      const list = toolsByPriority(p);
      const meta = priorityMeta[p];
      return (
        <section class="priority-section">
          <div class="priority-header">
            <h2>{meta.label}</h2>
            <span class="priority-tag" style={`background:${meta.bg};color:${meta.color}`}>{p} · {list.length} 个</span>
            <span class="priority-desc">{meta.desc}</span>
          </div>
          <div class="tool-grid">
            {list.map(t => (
              <a href={`/${t.slug}`} class="tool-card-home">
                <div class="card-icon">{t.icon}</div>
                <h3>{t.name}</h3>
                <p>{t.desc}</p>
                <div class="card-meta">
                  <span>{t.category}</span>
                  <span>日均 {t.volume} 搜索</span>
                </div>
              </a>
            ))}
          </div>
        </section>
      );
    })}

    <!-- 关于 -->
    <section class="seo-content">
      <h2>关于 HyperGrad Image</h2>
      <p>
        HyperGrad Image 是一个纯前端的图片工具集合，收录了 <strong>{totalTools} 个</strong>日常开发与设计中高频使用的细分图片工具。
        与其他图片工具站不同，本站所有图片处理都在<strong>浏览器本地</strong>完成——你上传的 SVG、照片、GIF，
        永远不会通过网络发送到任何服务器。这意味着：
      </p>
      <ul>
        <li><strong>隐私安全</strong>：处理含 EXIF 的私人照片、商业设计稿，无需担心泄露。</li>
        <li><strong>离线可用</strong>：页面加载完成后，断网也能继续使用。</li>
        <li><strong>速度快</strong>：无网络往返，所有操作即时响应。</li>
        <li><strong>无广告</strong>：首年完全无广告，专注于体验。</li>
      </ul>
      <h3>差异化定位：避开 TinyPNG 主战场</h3>
      <p>
        本站刻意避开 PNG/JPG 压缩这个红海（TinyPNG、智图已是霸主），聚焦三个有差异化壁垒的品类：
        <strong>SVG 工具</strong>（优化、编辑、转 PNG）、<strong>现代格式转换</strong>（WebP/AVIF 双向互转）、
        <strong>EXIF 隐私</strong>（查看与清理）。这三个品类与 <a href="https://hypergrad.cn" target="_blank" rel="noopener">DeepSeal 加密笔记应用</a>
        的隐私心智天然契合——<strong>你的数据只有你说了算</strong>。
      </p>
      <h3>与 HyperGrad 生态的关系</h3>
      <p>
        HyperGrad Image 与 <a href="https://devtools.hypergrad.cn" target="_blank" rel="noopener">HyperGrad DevTools 开发者工具站</a>、
        <a href="https://hypergrad.cn" target="_blank" rel="noopener">DeepSeal 加密笔记应用</a> 同属 HyperGrad 生态。
        三款产品共享同一个核心理念：<strong>本地处理、隐私优先、数据不离开设备</strong>。
      </p>
    </section>
  </main>

  <Footer />

  <style is:global>
    .quick-nav {
      margin: 28px 0 8px;
      padding: 16px 20px;
      background: var(--bg-soft);
      border: 1px solid var(--border);
      border-radius: 12px;
    }
    .quick-nav-title {
      font-size: 12px;
      color: var(--text-muted);
      margin-bottom: 10px;
      font-weight: 600;
      letter-spacing: 0.5px;
    }
    .quick-nav-chips {
      display: flex;
      gap: 8px;
      overflow-x: auto;
      padding-bottom: 4px;
      scrollbar-width: thin;
    }
    .quick-nav-chips::-webkit-scrollbar { height: 6px; }
    .quick-nav-chips::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }
    .quick-chip {
      flex-shrink: 0;
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 6px 14px;
      background: #fff;
      border: 1px solid var(--border);
      border-radius: 20px;
      font-size: 13px;
      color: var(--text);
      text-decoration: none;
      white-space: nowrap;
      transition: all 0.15s ease;
    }
    .quick-chip:hover {
      background: var(--blue);
      color: #fff;
      border-color: var(--blue);
    }
    .quick-chip-icon { font-size: 14px; }
  </style>
</body>
</html>
